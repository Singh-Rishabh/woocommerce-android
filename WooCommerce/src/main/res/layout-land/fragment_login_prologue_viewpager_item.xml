<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        tools:src="@drawable/img_prologue_analytics" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/prologueTitle"
        style="@style/Woo.TextView.Headline5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="37dp"
        android:breakStrategy="balanced"
        android:gravity="center"
        android:textStyle="bold"
        tools:text="@string/login_prologue_label_analytics" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/prologueSubtitle"
        style="@style/Woo.TextView.Subtitle1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/prologueTitle"
        tools:text="@string/login_prologue_label_analytics" />
</LinearLayout>
